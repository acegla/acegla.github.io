# Token bota z discord.com/developers
DISCORD_TOKEN=your_discord_bot_token

# GitHub Personal Access Token (scope: contents:write)
# Utwórz na: github.com/settings/tokens → Fine-grained tokens
GITHUB_TOKEN=your_github_pat

# Format: username/repo-name (np. jankowalski/blog)
GITHUB_REPO=username/your-jekyll-blog

# Branch bazowy (main/master) — bot nigdy tu nie commituje bezpośrednio
GITHUB_BRANCH=main

# Branch na drafty — tworzony automatycznie, PR → GITHUB_BRANCH
GITHUB_DRAFT_BRANCH=drafts

# Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_key

# ID kanału Discord — prawym przyciskiem na kanał → "Copy Channel ID"
# (wymaga włączenia trybu deweloperskiego w ustawieniach Discorda)
BLOG_CHANNEL_ID=123456789012345678

# Język postów: pl lub en
BLOG_LANG=pl
